# 正向 WebSocket 连接（Forward WebSocket）
# 用于连接已在局域网/本机运行的 OneBot 正向 WS 服务
ONEBOT_WS_TYPE=forward-websocket
ONEBOT_WS_HOST=127.0.0.1
ONEBOT_WS_PORT=8080
ONEBOT_WS_ACCESS_TOKEN=your-access-token

# 反向 WebSocket 时使用（可选）
# ONEBOT_WS_TYPE=backward-websocket
# ONEBOT_WS_PATH=/onebot/v11/ws

# 数据库目录（仅在不使用 configPath 时作为 ONEBOT_CORE_HOME 的 fallback）
# ONEBOT_CORE_HOME=
# AUTHORIZED_USERS=111111,2222222,3333333